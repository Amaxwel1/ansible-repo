<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Relatório - Mock Automation (Dia Anterior)</title>
  <style>
    body { font-family: Arial, sans-serif; font-size: 14px; }
    h1, h2, h3 { color: #1f2937; }
    table { border-collapse: collapse; width: 100%; margin-bottom: 20px; }
    th, td { border: 1px solid #d1d5db; padding: 6px 8px; text-align: left; }
    th { background: #e5e7eb; }
    .ok { color: #16a34a; font-weight: bold; }
    .fail { color: #dc2626; font-weight: bold; }
  </style>
</head>
<body>
  <h1>Relatório - Automação Dia Anterior (Mock)</h1>
  <p>Gerado em: {{ ansible_date_time.date }} {{ ansible_date_time.time }}</p>

  {% set _steps_raw = report['steps'] | default([]) %}
  {% set steps = _steps_raw if (_steps_raw is sequence and _steps_raw is not string) else ([_steps_raw] if _steps_raw else []) %}

  {% if steps %}
    <p><strong>STEP(s) selecionados:</strong></p>
    <ul>
      {% for s in steps %}
        <li>{{ s }}</li>
      {% endfor %}
    </ul>
  {% endif %}

  {# flags (se não existir, assume "mostra tudo") #}
  {% set flags = report['steps_flags'] | default({}) %}
  {% set show_deploys = flags['deploys'] | default(true) %}
  {% set show_umdf    = flags['umdf']    | default(true) %}
  {% set show_fix     = flags['fix']     | default(true) %}
  {% set show_db      = flags['db']      | default(true) %}

  {# aliases seguros (usar colchetes evita conflito com métodos como .items) #}
  {% set deploys = report['deploys'] | default({}) %}
  {% set umdf = report['umdf'] | default({}) %}
  {% set umdf_env = report['umdf_env'] | default({}) %}
  {% set fix = report['fix'] | default({}) %}
  {% set db = report['db'] | default({}) %}
  {% set dbconf = db['config'] | default({}) %}
  {% set dbins = db['inserts'] | default({}) %}

  {# contador de seções (1,2,3...) #}
  {% set sec = namespace(idx=0) %}

  {# 1) Imagens dos Deployments - só se tiver deploys e step permitir #}
  {% if show_deploys and (deploys is mapping) and (deploys | length > 0) %}
    {% set sec.idx = sec.idx + 1 %}
    <h2>{{ sec.idx }}. Imagens dos Deployments (PRD → TH)</h2>
    <table>
      <thead>
        <tr>
          <th>Deployment</th>
          <th>Imagem PRD (antes)</th>
          <th>Imagem TH (antes)</th>
          <th>Imagem TH (depois)</th>
          <th>Alterado?</th>
        </tr>
      </thead>
      <tbody>
      {% for it in (deploys | dict2items) %}
        {% set name = it.key %}
        {% set info = it.value %}
        <tr>
          <td>{{ name }}</td>
          <td>{{ info.prd_image_before | default('') }}</td>
          <td>{{ info.th_image_before | default('') }}</td>
          <td>{{ info.th_image_after | default('') }}</td>
          <td>
            {% if info.changed | default(false) %}
              <span class="ok">SIM</span>
            {% else %}
              NÃO
            {% endif %}
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  {% endif %}

  {# 2) UMDF (versão + hosts) - só se step permitir #}
  {% set has_umdf_data = (umdf is mapping and (umdf | length > 0)) %}
  {% set has_umdf_env  = (umdf_env is mapping and (umdf_env['targets'] is defined) and (umdf_env['targets'])) %}
  {% if show_umdf and (has_umdf_data or has_umdf_env) %}
    {% set sec.idx = sec.idx + 1 %}
    <h2>{{ sec.idx }}. Status do UMDF</h2>

    {% if has_umdf_data %}
      <p>JAR TH atual: <strong>{{ umdf.hml_jar | default('N/A') }}</strong></p>
      <p>JAR PRD atual: <strong>{{ umdf.prd_jar | default('N/A') }}</strong></p>
      <p>Comparação TH x PRD:
        {% if umdf.versions_match | default(false) %}
          <span class="ok">OK (iguais)</span>
        {% else %}
          <span class="fail">DIFERENTES</span>
        {% endif %}
      </p>
    {% endif %}

    {% if has_umdf_env %}
      <h3>Validação de UMDF host (TH)</h3>
      <p>Host TH esperado:
        <strong>{{ umdf_env.expected_hml | default('N/A') }}</strong>
      </p>
      <table>
        <tr>
          <th>Namespace</th>
          <th>DC</th>
          <th>umdf_bmf_host</th>
          <th>umdf_bvsp_host</th>
          <th>bmf_ok</th>
          <th>bvsp_ok</th>
        </tr>
        {% for row in umdf_env['targets'] %}
        <tr>
          <td>{{ row.namespace }}</td>
          <td>{{ row.dc }}</td>
          <td>{{ row.umdf_bmf_host }}</td>
          <td>{{ row.umdf_bvsp_host }}</td>
          <td>
            {% if row.bmf_ok | default(false) %}
              <span class="ok">OK</span>
            {% else %}
              <span class="fail">DIF</span>
            {% endif %}
          </td>
          <td>
            {% if row.bvsp_ok | default(false) %}
              <span class="ok">OK</span>
            {% else %}
              <span class="fail">DIF</span>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </table>
    {% endif %}
  {% endif %}

  {# 3) FIX - só se step permitir #}
  {% set steps_is_empty = (steps | length == 0) %}

  {% set has_step_trocar =
        ('TROCAR FLAVOR' in steps) or ('TROCAR FLAVOUR' in steps) or steps_is_empty
  %}
  {% set has_step_voltar =
        ('VOLTAR FLAVOR' in steps) or ('VOLTAR FLAVOUR' in steps)
  %}

  {% if show_fix and (fix is mapping) and (fix | length > 0) and (has_step_trocar or has_step_voltar) %}
    {% set sec.idx = sec.idx + 1 %}

    {% if has_step_trocar %}
      <h2>{{ sec.idx }}. Status do FIX / Heartbeat</h2>

      <p>FLAVOUR ativo atual:
        <strong>{{ fix.flavour_active | default('N/A') }}</strong>
      </p>

      <p>Heartbeat:
        {% if fix.heartbeat_ok | default(false) %}
          <span class="ok">OK</span>
        {% else %}
          <span class="fail">SEM HEARTBEAT</span>
        {% endif %}
      </p>
      <p>Problema de MsgSeqNum detectado:
        {% if fix.has_msgseq_issue | default(false) %}
          <span class="fail">SIM</span>
        {% else %}
          NÃO
        {% endif %}
      </p>
      <p>SESSION_RESTART aplicado:
        {% if fix.session_restart_applied | default(false) %}
          <span class="ok">SIM</span>
        {% else %}
          NÃO
        {% endif %}
      </p>

    {% elif has_step_voltar %}
      <h2>{{ sec.idx }}. FIX – Voltar FLAVOUR</h2>

      <p>FLAVOUR ativo atual:
        <strong>{{ fix.flavour_active | default('N/A') }}</strong>
      </p>

      {% if fix.restore_before is defined or fix.restore_after is defined %}
        <p><strong>FLAVOUR antes do restore:</strong> {{ fix.restore_before | default('N/A') }}</p>
        <p><strong>FLAVOUR após o restore:</strong> {{ fix.restore_after | default('N/A') }}</p>
      {% endif %}

      {% if fix.restore_ok is defined %}
        <p>Status do restore:
          {% if fix.restore_ok %}
            <span class="ok">OK</span>
          {% else %}
            <span class="fail">FALHA</span>
          {% endif %}
        </p>
      {% endif %}
    {% endif %}
  {% endif %}

  {# 4) Banco – INSERTs / Configuração do Mock (menos poluído) #}
  {% set dbins = db['inserts'] | default({}) %}
  {% if dbins.executed | default(false) %}
    {% set sec.idx = sec.idx + 1 %}
    <h2>{{ sec.idx }}. Banco de Dados – INSERTs / Configuração do Mock</h2>

    {# pega lista real sem colidir com .items() #}
    {% set ins_items = dbins['items'] | default([]) %}

    {# contadores #}
    {% set total = ins_items | length %}
    {% set ok_count = namespace(n=0) %}
    {% set err_count = namespace(n=0) %}

    {% for r in ins_items %}
      {% if r.failed | default(false) %}
        {% set err_count.n = err_count.n + 1 %}
      {% else %}
        {% set ok_count.n = ok_count.n + 1 %}
      {% endif %}
    {% endfor %}

    <p>
      <strong>Total:</strong> {{ total }} |
      <strong>OK:</strong> {{ ok_count.n }} |
      <strong>Erros:</strong> {{ err_count.n }}
    </p>

    {% if err_count.n == 0 %}
      <p class="ok">Sem erros nos INSERTs.</p>
    {% else %}
      <p class="fail">Foram encontrados {{ err_count.n }} erro(s) nos INSERTs.</p>

      <h3>Erros (somente)</h3>
      <table>
        <thead>
          <tr>
            <th>Query</th>
            <th>Mensagem</th>
          </tr>
        </thead>
        <tbody>
          {% for r in ins_items %}
            {% if r.failed | default(false) %}
              {% set qname = (r.item.name if (r.item is defined and r.item.name is defined) else '—') %}
              <tr>
                <td>{{ qname }}</td>
                <td>{{ r.msg | default('Erro não informado') }}</td>
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  {% endif %}

  {# 5) Banco – Configuração FIX - só se step permitir #}
  {% if show_db and (dbconf is mapping) and (dbconf.mock_flavour_id is defined) %}
    {% set sec.idx = sec.idx + 1 %}
    <h2>{{ sec.idx }}. Banco de Dados – Configuração FIX ({{ fix_flavour_target }})</h2>

    <p><strong>ID Flavour:</strong> {{ dbconf.mock_flavour_id }}</p>

    <h3>5.1 tb_fix_server_configuration_flavour</h3>
    {% if dbconf.flavour %}
      {% set flavour_cols = dbconf.flavour[0].keys() | list %}
      <table>
        <tr>
          {% for col in flavour_cols %}
            <th>{{ col }}</th>
          {% endfor %}
        </tr>
        {% for row in dbconf.flavour %}
          <tr>
            {% for col in flavour_cols %}
              <td>{{ row[col] }}</td>
            {% endfor %}
          </tr>
        {% endfor %}
      </table>
    {% else %}
      <p>Nenhuma linha na flavour.</p>
    {% endif %}

    <h3>5.2 tb_fix_server_configuration_session</h3>
    {% if dbconf.session %}
      {% set session_cols = dbconf.session[0].keys() | list %}
      <table>
        <tr>
          {% for col in session_cols %}
            <th>{{ col }}</th>
          {% endfor %}
        </tr>
        {% for row in dbconf.session %}
          <tr>
            {% for col in session_cols %}
              <td>{{ row[col] }}</td>
            {% endfor %}
          </tr>
        {% endfor %}
      </table>
    {% else %}
      <p>Nenhuma linha em session.</p>
    {% endif %}

    <h3>5.3 tb_fix_server_configuration_default</h3>
    {% if dbconf.default %}
      {% set default_cols = dbconf.default[0].keys() | list %}
      <table>
        <tr>
          {% for col in default_cols %}
            <th>{{ col }}</th>
          {% endfor %}
        </tr>
        {% for row in dbconf.default %}
          <tr>
            {% for col in default_cols %}
              <td>{{ row[col] }}</td>
            {% endfor %}
          </tr>
        {% endfor %}
      </table>
    {% else %}
      <p>Nenhuma linha em default.</p>
    {% endif %}
  {% endif %}

  {% if sec.idx == 0 %}
    <h2>Nenhuma seção foi gerada</h2>
    <p>O STEP selecionado não produziu dados para relatório (ou as tasks correspondentes não foram executadas).</p>
  {% endif %}

</body>
</html>
