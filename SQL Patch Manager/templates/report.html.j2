<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Relatório - SQL Patch Manager</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      font-size: 14px;
      color: #111827;
    }

    h1 {
      color: #1f2937;
      font-size: 22px;
      margin-bottom: 10px;
    }

    h2 {
      color: #1f2937;
      font-size: 18px;
      margin-top: 24px;
      margin-bottom: 10px;
    }

    h3 {
      color: #1f2937;
      font-size: 15px;
      margin-top: 18px;
      margin-bottom: 8px;
    }

    p {
      margin: 8px 0 12px 0;
    }

    table {
      border-collapse: collapse;
      width: 100%;
      margin-bottom: 18px;
    }

    th, td {
      border: 1px solid #a2a2a2;
      padding: 10px;
      text-align: left;
      vertical-align: top;
    }

    th {
      background: #e0e0e0;
    }

    .ok { background: #d1fae5; }
    .warn { background: #fef3c7; }
    .bad { background: #fee2e2; }

    .mono {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      "Liberation Mono", "Courier New", monospace;
      white-space: pre-wrap;
      word-break: break-word;
    }

    .summary-table td:first-child {
      width: 240px;
      font-weight: bold;
      background: #f3f4f6;
    }

    .subtle {
      color: #4b5563;
      font-size: 13px;
    }

    .badge-ok {
      display: inline-block;
      padding: 3px 8px;
      border-radius: 10px;
      background: #d1fae5;
      color: #065f46;
      font-weight: bold;
      font-size: 12px;
    }

    .badge-bad {
      display: inline-block;
      padding: 3px 8px;
      border-radius: 10px;
      background: #fee2e2;
      color: #991b1b;
      font-weight: bold;
      font-size: 12px;
    }

    .note {
      margin-top: 6px;
      margin-bottom: 14px;
      color: #4b5563;
      font-size: 13px;
    }

    .small-note {
      margin-top: -6px;
      margin-bottom: 14px;
      color: #4b5563;
      font-size: 12px;
    }
  </style>
</head>
<body>

<h1>Relatório - SQL Patch Manager</h1>

<h2>Resumo da execução</h2>
<table class="summary-table">
  <tr>
    <td>Executor</td>
    <td class="mono">{{ patch_report.execution.executor | default('—') }}</td>
  </tr>
  <tr>
    <td>Motivo</td>
    <td class="mono">{{ patch_report.execution.motivo | default('—') }}</td>
  </tr>
  <tr>
    <td>Ambiente</td>
    <td class="mono">{{ patch_report.execution.environment | default('—') }}</td>
  </tr>
  <tr>
    <td>Topologia</td>
    <td class="mono">{{ patch_report.execution.topology | default('—') }}</td>
  </tr>
  <tr>
    <td>Modo pré-check only</td>
    <td class="mono">{{ patch_report.execution.precheck_only | default(false) }}</td>
  </tr>
  <tr>
    <td>Hosts informados no survey</td>
    <td class="mono">{{ patch_report.execution.requested_hosts_raw | default('—') }}</td>
  </tr>
  <tr>
    <td>Hosts alvo da execução</td>
    <td class="mono">{{ patch_report.execution.execution_hosts | join(', ') if patch_report.execution.execution_hosts is defined else '—' }}</td>
  </tr>
  <tr>
    <td>Instância(s) SQL</td>
    <td class="mono">{{ patch_report.execution.instance_name | default('—') }}</td>
  </tr>
  {% if patch_report.execution.patch_package_name is defined and patch_report.execution.patch_package_name %}
  <tr>
    <td>Patch</td>
    <td class="mono">{{ patch_report.execution.patch_package_name }}</td>
  </tr>
  {% endif %}
</table>

{% if patch_report.execution.topology == 'single' %}

<h2>Estado inicial das instâncias</h2>
<table>
  <tr>
    <th>Host</th>
    <th>Instância</th>
    <th>Serviço</th>
    <th>Estado</th>
    <th>Connection Target</th>
  </tr>
  {% for host, instances in (patch_report.discovery.sql_instances_by_host | default({})).items() %}
    {% for inst in instances %}
    <tr class="{{ 'ok' if (inst.State | default('') | upper) == 'RUNNING' else 'warn' }}">
      <td class="mono">{{ host }}</td>
      <td class="mono">{{ inst.InstanceName | default('—') }}</td>
      <td class="mono">{{ inst.ServiceName | default('—') }}</td>
      <td class="mono">{{ inst.State | default('—') }}</td>
      <td class="mono">{{ inst.ConnectionTarget | default('—') }}</td>
    </tr>
    {% endfor %}
  {% endfor %}
</table>

<h2>Precheck</h2>
<table>
  <tr>
    <th>Host</th>
    <th>Instância</th>
    <th>Connection Target</th>
    <th>Versão antes</th>
  </tr>
  {% for row in patch_report.precheck.single_precheck_rows | default([]) %}
  <tr class="{{ 'ok' if (row.version_before_rc | default(1) | int) == 0 else 'bad' }}">
    <td class="mono">{{ row.host | default('—') }}</td>
    <td class="mono">{{ row.instance_name | default('—') }}</td>
    <td class="mono">{{ row.connection_target | default('—') }}</td>
    <td class="mono">{{ row.version_before | default('—') }}</td>
  </tr>
  {% endfor %}
</table>

<h2>Estado final das instâncias</h2>
<table>
  <tr>
    <th>Host</th>
    <th>Instância</th>
    <th>Connection Target</th>
    <th>Status final</th>
  </tr>
  {% for row in patch_report.postcheck.single_postcheck_rows | default([]) %}
  <tr class="{{ 'ok' if (row.version_after_rc | default(1) | int) == 0 else 'bad' }}">
    <td class="mono">{{ row.host | default('—') }}</td>
    <td class="mono">{{ row.instance_name | default('—') }}</td>
    <td class="mono">{{ row.connection_target | default('—') }}</td>
    <td>
      {% if (row.version_after_rc | default(1) | int) == 0 %}
        <span class="badge-ok">OK</span>
      {% else %}
        <span class="badge-bad">FALHOU</span>
      {% endif %}
    </td>
  </tr>
  {% endfor %}
</table>

{% else %}

<h2>Estado inicial do AG</h2>
<table>
  <tr>
    <th>Host</th>
    <th>Role</th>
    <th>Availability Mode</th>
    <th>Connected</th>
    <th>Health</th>
  </tr>
  {% for row in patch_report.precheck.ag_initial_topology_rows | default([]) %}
  <tr class="{{ 'ok' if row.SyncHealth | default('') == 'HEALTHY' else 'bad' }}">
    <td class="mono">{{ row.InventoryHost | default(row.MachineName | default('—')) }}</td>
    <td class="mono">{{ row.RoleName | default('—') }}</td>
    <td class="mono">{{ row.AvailabilityMode | default('—') }}</td>
    <td class="mono">{{ row.ConnectedState | default('—') }}</td>
    <td class="mono">{{ row.SyncHealth | default('—') }}</td>
  </tr>
  {% endfor %}
</table>

<h2>Precheck</h2>

<h3>Remote Registry</h3>
{% if patch_report.precheck.remote_registry_status_by_host is defined and patch_report.precheck.remote_registry_status_by_host %}
<table>
  <tr>
    <th>Host</th>
    <th>Start mode</th>
    <th>State</th>
    <th>Status</th>
  </tr>
  {% for host, data in patch_report.precheck.remote_registry_status_by_host.items() %}
  <tr class="{{ 'ok' if not (data.failed | default(false)) else 'bad' }}">
    <td class="mono">{{ host }}</td>
    <td class="mono">{{ data.start_mode | default('—') }}</td>
    <td class="mono">{{ data.state | default('—') }}</td>
    <td>
      {% if not (data.failed | default(false)) %}
        <span class="badge-ok">OK</span>
      {% else %}
        <span class="badge-bad">FALHOU</span>
      {% endif %}
    </td>
  </tr>
  {% endfor %}
</table>
{% else %}
<p>Sem informações de Remote Registry.</p>
{% endif %}

{% set db_rows = patch_report.precheck.ag_database_health_rows | default([]) %}
{% set db_problem_rows = db_rows
  | rejectattr('SynchronizationHealthDesc', 'equalto', 'HEALTHY')
  | list %}
{% set db_primary_state_bad = db_rows
  | selectattr('RoleName', 'equalto', 'PRIMARY')
  | rejectattr('DatabaseStateDesc', 'equalto', 'ONLINE')
  | list %}
{% set db_suspended = db_rows
  | selectattr('IsSuspended', 'equalto', 1)
  | list %}
{% set db_problem_count = (db_problem_rows | length) + (db_primary_state_bad | length) + (db_suspended | length) %}

<h3>Resumo do health por database</h3>
<table>
  <tr>
    <th>Total avaliado</th>
    <th>Com problema de sincronização</th>
    <th>PRIMARY fora de ONLINE</th>
    <th>Suspensos</th>
  </tr>
  <tr class="{{ 'ok' if db_problem_count == 0 else 'warn' }}">
    <td class="mono">{{ db_rows | length }}</td>
    <td class="mono">{{ db_problem_rows | length }}</td>
    <td class="mono">{{ db_primary_state_bad | length }}</td>
    <td class="mono">{{ db_suspended | length }}</td>
  </tr>
</table>

{% if db_problem_count > 0 %}
<h3>Databases com problema</h3>
<table>
  <tr>
    <th>Server</th>
    <th>Role</th>
    <th>Database</th>
    <th>Sync State</th>
    <th>Sync Health</th>
    <th>Database State</th>
    <th>Suspended</th>
  </tr>
  {% for row in db_rows %}
  {% set row_problem =
      (row.SynchronizationHealthDesc | default('') != 'HEALTHY')
      or (row.RoleName | default('') == 'PRIMARY' and row.DatabaseStateDesc | default('') != 'ONLINE')
      or ((row.IsSuspended | default(0) | int) == 1)
  %}
  {% if row_problem %}
  <tr class="bad">
    <td class="mono">{{ row.ServerName | default('—') }}</td>
    <td class="mono">{{ row.RoleName | default('—') }}</td>
    <td class="mono">{{ row.DatabaseName | default('—') }}</td>
    <td class="mono">{{ row.SynchronizationStateDesc | default('—') }}</td>
    <td class="mono">{{ row.SynchronizationHealthDesc | default('—') }}</td>
    <td class="mono">{{ row.DatabaseStateDesc | default('—') if row.DatabaseStateDesc | default('') else '—' }}</td>
    <td class="mono">{{ row.IsSuspended | default('—') }}</td>
  </tr>
  {% endif %}
  {% endfor %}
</table>
{% endif %}

<h2>Estado final do AG</h2>
<table>
  <tr>
    <th>Host</th>
    <th>Role</th>
    <th>Availability Mode</th>
    <th>Connected</th>
    <th>Health</th>
  </tr>
  {% for row in patch_report.postcheck.ag_final_topology_rows | default([]) %}
  <tr class="{{ 'ok' if row.SyncHealth | default('') == 'HEALTHY' else 'bad' }}">
    <td class="mono">{{ row.InventoryHost | default(row.MachineName | default('—')) }}</td>
    <td class="mono">{{ row.RoleName | default('—') }}</td>
    <td class="mono">{{ row.AvailabilityMode | default('—') }}</td>
    <td class="mono">{{ row.ConnectedState | default('—') }}</td>
    <td class="mono">{{ row.SyncHealth | default('—') }}</td>
  </tr>
  {% endfor %}
</table>

{% endif %}

{% set summary_action = (patch_report.actions | selectattr('step', 'equalto', 'ag_patch_summary') | list | first) %}

<h2>Ações executadas</h2>
{% set visible_actions = patch_report.actions | rejectattr('step', 'equalto', 'ag_patch_summary') | list %}
{% if visible_actions | length == 0 %}
  <p>Nenhuma ação registrada.</p>
{% else %}
<table>
  <tr>
    <th>Host</th>
    <th>Instância</th>
    <th>Etapa</th>
    <th>Detalhe</th>
  </tr>
  {% for item in visible_actions %}
    {% set rc = item.rc | default('') %}
    {% set row_class = 'ok' %}
    {% if item.step in ['wait_ag_healthy', 'wait_single_instance_ready'] %}
      {% set row_class = 'ok' %}
    {% elif rc != '' and (rc | int) not in [0, 3010] %}
      {% set row_class = 'bad' %}
    {% endif %}

    {% if item.step == 'patch' %}
      {% set step_label = 'Aplicação de patch' %}
    {% elif item.step == 'planned_failover' %}
      {% set step_label = 'Execução de failover' %}
    {% elif item.step == 'wait_ag_healthy' %}
      {% set step_label = 'Aguardando AG ficar saudável' %}
    {% elif item.step == 'wait_single_instance_ready' %}
      {% set step_label = 'Validação final da instância' %}
    {% elif item.step == 'reboot_after_validation' %}
      {% set step_label = 'Reboot após validação final' %}
    {% elif item.step == 'wait_single_instance_ready_after_reboot' %}
      {% set step_label = 'Validação da instância após reboot' %}
    {% else %}
      {% set step_label = item.step %}
    {% endif %}

    <tr class="{{ row_class }}">
      <td class="mono">{{ item.host | default('—') }}</td>
      <td class="mono">{{ item.instance_name | default('—') }}</td>
      <td>{{ step_label }}</td>
      <td>
        {% if item.step == 'wait_ag_healthy' %}
          <span class="mono">AG saudável após a etapa anterior.</span>
        {% elif item.step == 'wait_single_instance_ready' %}
          <span class="mono">Instância pronta para pós-check.</span>
        {% elif item.message is defined and item.message %}
          <span class="mono">{{ item.message }}</span>
        {% elif item.stdout is defined and item.stdout %}
          <span class="mono">{{ item.stdout }}</span>
        {% else %}
          <span class="mono">—</span>
        {% endif %}
      </td>
    </tr>
  {% endfor %}
</table>
{% endif %}

{% if summary_action is defined and summary_action %}
<p class="small-note"><b>Resumo do fluxo:</b> {{ summary_action.message | default('—') }}</p>
{% endif %}

{% if patch_report.execution.topology == 'single' %}

<h2>Pós-check</h2>
<table>
  <tr>
    <th>Host</th>
    <th>Instância</th>
    <th>Connection Target</th>
    <th>Versão após patch</th>
  </tr>
  {% for row in patch_report.postcheck.single_postcheck_rows | default([]) %}
  <tr class="{{ 'ok' if (row.version_after_rc | default(1) | int) == 0 else 'bad' }}">
    <td class="mono">{{ row.host | default('—') }}</td>
    <td class="mono">{{ row.instance_name | default('—') }}</td>
    <td class="mono">{{ row.connection_target | default('—') }}</td>
    <td class="mono">{{ row.version_after | default('—') }}</td>
  </tr>
  {% endfor %}
</table>

{% else %}

<h2>Pós-check</h2>
<table>
  <tr>
    <th>Host</th>
    <th>Versão após patch</th>
  </tr>
  {% for host, data in (patch_report.postcheck.sql_postcheck_by_host | default({})).items() %}
  <tr class="{{ 'ok' if (data.version_after_rc | default(1) | int) == 0 else 'bad' }}">
    <td class="mono">{{ host }}</td>
    <td class="mono">{{ data.version_after | default('—') }}</td>
  </tr>
  {% endfor %}
</table>

{% endif %}

</body>
</html>