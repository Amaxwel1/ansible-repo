patch_cifs_share_root: "\\ag-ah-vv-fs-001.agorasenior.corp\apps"
patch_cifs_subpath: "ansible\BD_SQLSERVER"

- name: Copiar patch do share SMB para o host {{ patch_target_host }}
  ansible.windows.win_powershell:
    script: |
      $shareRoot = "{{ patch_cifs_share_root }}"
      $subPath   = "{{ patch_cifs_subpath }}"
      $username  = "{{ patch_cifs_username }}"
      $password  = "{{ patch_cifs_password }}"
      $domain    = "{{ patch_cifs_domain | default('') }}"
      $dest      = "{{ windows_patch_stage_dir }}\{{ patch_package_name }}"

      if ([string]::IsNullOrWhiteSpace($domain) -or $username.Contains('\') -or $username.Contains('@')) {
        $fullUser = $username
      }
      else {
        $fullUser = "$domain\$username"
      }

      $securePassword = ConvertTo-SecureString $password -AsPlainText -Force
      $cred = New-Object System.Management.Automation.PSCredential($fullUser, $securePassword)

      $driveName = "PATCHSRC"

      try {
        if (Get-PSDrive -Name $driveName -ErrorAction SilentlyContinue) {
          Remove-PSDrive -Name $driveName -Force -ErrorAction SilentlyContinue
        }

        New-PSDrive -Name $driveName -PSProvider FileSystem -Root $shareRoot -Credential $cred -ErrorAction Stop | Out-Null

        $sourceFolder = Join-Path "${driveName}:\" $subPath

        if (-not (Test-Path $sourceFolder)) {
          throw "Subdiretório não encontrado no share: $sourceFolder"
        }

        $file = Get-ChildItem -Path $sourceFolder -File -Recurse -ErrorAction Stop |
          Where-Object { $_.Name -eq "{{ patch_package_name }}" } |
          Select-Object -First 1

        if (-not $file) {
          throw "Arquivo não encontrado no share: {{ patch_package_name }}"
        }

        Copy-Item -Path $file.FullName -Destination $dest -Force -ErrorAction Stop

        [pscustomobject]@{
          ok           = $true
          shareRoot    = $shareRoot
          subPath      = $subPath
          sourceFolder = $sourceFolder
          src          = $file.FullName
          dest         = $dest
        } | ConvertTo-Json -Compress -Depth 5
      }
      finally {
        if (Get-PSDrive -Name $driveName -ErrorAction SilentlyContinue) {
          Remove-PSDrive -Name $driveName -Force -ErrorAction SilentlyContinue
        }
      }
  delegate_to: "{{ patch_target_host }}"
  register: _patch_copy
  changed_when: true
  no_log: true
